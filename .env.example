# API ключ для Groq (обязательно)
# Получите свой ключ на https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Настройки Groq (опционально, по умолчанию используются значения из config.py)
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ===== Обработка капчи (CAPTCHA) =====
# Автоматически обрабатывать капчи при их обнаружении
# По умолчанию: true
# CAPTCHA_AUTO_HANDLE=true

# Таймаут ожидания ручного решения капчи (в секундах)
# По умолчанию: 300 (5 минут)
# CAPTCHA_MANUAL_TIMEOUT=300

# ===== Автоматическое решение капчи (опционально) =====
# Поддерживаемые сервисы: "2captcha", "anticaptcha"
# Требует платной подписки на сервис
# CAPTCHA_SOLVER_SERVICE=2captcha
# CAPTCHA_SOLVER_API_KEY=your_2captcha_api_key

# Стоимость:
# - 2Captcha: https://2captcha.com (~$2.99 за 1000 капч)
# - AntiCaptcha: https://anti-captcha.com (~$1.60 за 1000 капч)
